# Copy this file to .env and fill in your values.
# Defaults are shown (all are optional unless noted).

# Finnhub API key for US/USD price lookups (optional fallback)
# FINNHUB_API_KEY=

# App environment (local | production)
# APP_ENV=local

# Path to the JSON portfolio file
# PORTFOLIO_JSON_PATH=data/portfolio.json

# Path to the JSON tax profile file (carryforward inputs)
# TAX_PROFILE_JSON_PATH=data/tax_profile.json

# Path to the disk-backed ticker metadata cache (survives Streamlit restarts)
# TICKER_CACHE_JSON_PATH=data/ticker_cache.json
